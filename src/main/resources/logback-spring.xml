<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimal logback configuration that delegates to Spring Boot defaults but
     provides a simple console appender and includes the MDC requestId if present.
     Keeping a small well-formed config here avoids SAX parsing errors in tests
     while following standard Spring Boot logging practice. -->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%X{requestId:-}] %logger{36} - %msg%n</pattern>
            <charset>utf-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>

